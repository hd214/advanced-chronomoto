{
  "manifest_version": 3,
  "name": "Chronomoto Row Highlighter (Kiosk)",
  "version": "1.0",
  "description": "Highlights a rider row on live.chronomoto.com",
  "content_scripts": [
    {
      "matches": ["https://live.chronomoto.com/*"],
      "exclude_matches": ["https://live.chronomoto.com/archive*"],
      "js": ["content.js"],
      "run_at": "document_idle",
      "all_frames": false
    }
  ]
}
