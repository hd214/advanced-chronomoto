# Chronomoto Pi kiosk configuration
# Copy to chronomoto.conf and edit before running setup.sh:
#   cp chronomoto.conf.example chronomoto.conf
#
# Or pass the same names as environment variables to setup.sh.

# Rider number to highlight in the live timing iframe (leave empty to disable)
HIGHLIGHT_NO=214

# Top panel: live timing URL
TOP_URL=https://live.chronomoto.com/mx/

# Bottom panel: archive URL
BOTTOM_URL=https://live.chronomoto.com/archive

# Label shown on the archive badge in the split-view top bar
ARCHIVE_TITLE=ARCHIVE

# Default top/bottom split ratio (percent for top panel)
DEFAULT_SPLIT=60

# Archive refresh interval in milliseconds (default: 60000 = 1 minute)
ARCHIVE_REFRESH_MS=60000

# Enable the analog clock in the top-right panel (1 = enabled, 0 = disabled)
# Set to 0 to hide the clock and give the top panel full width.
CLOCK_ENABLED=1

# Archive refresh interval in milliseconds (default: 60000 = 1 minute)
ARCHIVE_REFRESH_MS=60000
